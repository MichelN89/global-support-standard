# GSS provider endpoint this webshop exposes
GSS_PROVIDER_ENDPOINT=http://127.0.0.1:8010/v1
GSS_PROVIDER_HOST=127.0.0.1
GSS_PROVIDER_PORT=8010
GSS_PROVIDER_DEBUG=false
GSS_SHOP_NAME=Example Shop

# Shopify Admin API credentials
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2024-10

# Runtime token settings for local development
GSS_TOKEN_TTL_SECONDS=3600

# Compliance signaling in describe
GSS_COMPLIANCE_LEVEL=basic
GSS_CERTIFIED=false
GSS_TEST_SUITE_VERSION=unverified
